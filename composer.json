{
  "name": "bridging/bridge",
  "description": "Thin Symfony-oriented bridge component for explicit handoff logic between ecosystem contracts.",
  "type": "symfony-bundle",
  "license": "proprietary",
  "require": {
    "php": ">=8.4",
    "symfony/framework-bundle": "^8.0",
    "symfony/yaml": "^8.0",
    "smart-responsor/objecting": "*@dev"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.88",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "App\\Bridging\\": "src/",
      "App\\Localizing\\": "../Localizing/src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Bridging\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "cs:fix": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --verbose",
    "cs:check": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --verbose",
    "phpstan": "phpstan analyse --configuration=phpstan.neon.dist",
    "test": "phpunit --configuration=phpunit.xml.dist"
  },
  "extra": {
    "branch-alias": {
      "dev-master": "0.1-dev"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "repositories": [
    {
      "type": "path",
      "url": "../Objecting",
      "options": {
        "symlink": true
      }
    }
  ]
}
